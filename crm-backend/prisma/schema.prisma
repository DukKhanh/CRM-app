generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  full_name     String
  email         String   @unique
  password_hash String
  avatar        String?
  role          String   @default("Employee") // Admin hoặc Employee
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  resetOtp    String?   
  otpExpiry   DateTime? 
  expoPushToken String?
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  company   String?
  address   String?
  status    String   @default("New") // New, Contacted, Converted, vv.
  tasks     Task[]   // Quan hệ 1-N với Task
  notes     Note[]   // Quan hệ 1-N với Note
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  deadline    DateTime?
  status      String   @default("Pending") // Pending, In Progress, Completed
  
  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Note {
  id          String   @id @default(uuid())
  content     String
  
  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}