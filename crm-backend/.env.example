# Server Port
PORT=3000

# Database Connection (Replace with your actual database URL)
DATABASE_URL="mysql://user:password@localhost:3306/crm_db"

# JWT Secret Key
JWT_SECRET="your-super-secret-jwt-key"

# Email Configuration for sending OTPs
# Use your Gmail address
EMAIL_USER="your-email@gmail.com"
# Use a 16-character App Password generated from Google Account Security (NOT your normal password)
EMAIL_PASS="your-16-char-app-password"
